{
  "source": "https://github.com/zyddnys/manga-image-translator",
  "note": "请放入可在浏览器端运行的 ONNX 模型文件，文本检测/OCR/去字优先支持 WebNN",
  "models": {
    "detector": {
      "name": "detector",
      "task": "text-detection",
      "url": "/models/detector.onnx",
      "input": [1024, 1024],
      "runtime": ["webgpu", "webnn", "wasm"]
    },
    "ocr": {
      "name": "ocr",
      "task": "japanese-ocr",
      "url": "/models/ocr.onnx",
      "input": [48, 320],
      "runtime": ["webgpu", "webnn", "wasm"],
      "dictUrl": "/models/ocr_dict.txt",
      "normalize": "minus_one_to_one"
    },
    "inpaint": {
      "name": "inpaint",
      "task": "text-removal",
      "url": "/models/lama_fp32.onnx",
      "input": [512, 512],
      "runtime": ["webgpu", "webnn", "wasm"],
      "normalize": "zero_to_one",
      "outputNormalize": "zero_to_255",
      "maskInputName": "mask"
    },
    "bubble": {
      "name": "bubble",
      "task": "bubble-segmentation",
      "url": "/models/bubble.onnx",
      "input": [640, 640],
      "runtime": ["webgpu", "webnn", "wasm"]
    }
  }
}
